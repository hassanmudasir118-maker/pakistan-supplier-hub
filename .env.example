# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://your-app.up.railway.app

# ─── Database (Railway Volume) ────────────────────────────────────────────────
# Mount a Railway Volume at /app/data then set these:
DB_PATH=/app/data/data.sqlite
UPLOADS_DIR=/app/data/uploads

# ─── JWT Secrets (REQUIRED — generate with: node -e "require('crypto').randomBytes(48).toString('hex')")
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_CHAR_HEX

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeMe@1234
ADMIN_NAME=Platform Admin

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
