# ============================================================================
# PAKISTAN SUPPLIER HUB — Environment configuration
# Copy this file to .env and fill in real values.
# Anything left blank degrades gracefully (see comments) but you should NOT
# go live on real money/orders until payments + email are configured.
# ============================================================================

PORT=3000
NODE_ENV=production
APP_URL=https://yourdomain.com

# --- Auth secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_this_with_a_long_random_string
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string

# --- Google OAuth (https://console.cloud.google.com/apis/credentials)
# Without these, the "Continue with Google" button is hidden automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback

# --- Outgoing email (verification + password reset)
# Without these, verification/reset links are logged to the server console
# instead of emailed — fine for local testing, NOT for production.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pakistan Supplier Hub <no-reply@yourdomain.com>"

# --- Easypaisa / JazzCash
# Real merchant API integration requires a signed merchant agreement with
# each provider (Telenor Microfinance Bank for Easypaisa, JazzCash/Mobilink
# for JazzCash) — they issue a Merchant ID + Integrity Salt/API key after
# approval. Until you have these, the platform uses the "manual" flow that's
# already fully built: the customer sends money to your EasyPaisa/JazzCash
# number and submits a transaction ID, which an admin verifies by hand. Add
# the keys below only once you have a real merchant account.
EASYPAISA_MERCHANT_ID=
EASYPAISA_API_KEY=
JAZZCASH_MERCHANT_ID=
JAZZCASH_API_KEY=

# --- AI Chat Assistant
# Get a key from https://console.anthropic.com (Account Settings -> API Keys).
# Without this, the chat widget shows "not configured yet" instead of crashing.
ANTHROPIC_API_KEY=

# --- WhatsApp Business (store management / customer chat via WhatsApp)
# Requires your own Meta Business account + WhatsApp Business API approval at
# https://business.facebook.com — Meta issues a Phone Number ID and a
# permanent access token once your business is verified. Until these are set,
# WhatsApp features stay hidden/disabled automatically.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# --- Admin bootstrap (creates this account on first boot if no super_admin exists)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChangeThisImmediately123!
ADMIN_NAME=Platform Admin
