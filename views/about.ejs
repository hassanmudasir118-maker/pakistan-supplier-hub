<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<main class="container" style="max-width:820px;padding:40px 20px 60px">
  <h1 style="font-size:28px">About Pakistan Supplier Hub</h1>
  <p style="color:var(--text-700);line-height:1.8;font-size:15px">Pakistan Supplier Hub is a multi-vendor wholesale and dropshipping marketplace built to connect suppliers, wholesalers, manufacturers, and importers across Pakistan with resellers and customers nationwide.</p>
  <p style="color:var(--text-700);line-height:1.8;font-size:15px">We make it simple for businesses of every size to list products, manage orders, and get paid — while customers and resellers get access to verified suppliers, transparent wholesale pricing, and a streamlined checkout experience with local payment methods including Cash on Delivery, Bank Transfer, EasyPaisa, and JazzCash.</p>

  <div class="cat-grid" style="grid-template-columns:repeat(3,1fr);margin-top:36px">
    <div class="card" style="padding:22px;text-align:center"><div style="font-size:28px">🏬</div><h3 style="font-size:14px;margin:10px 0 6px">Verified Suppliers</h3><p style="font-size:12.5px;color:var(--text-500)">Every vendor is reviewed before going live.</p></div>
    <div class="card" style="padding:22px;text-align:center"><div style="font-size:28px">📦</div><h3 style="font-size:14px;margin:10px 0 6px">Easy Dropshipping</h3><p style="font-size:12.5px;color:var(--text-500)">Import products with one click and set your own price.</p></div>
    <div class="card" style="padding:22px;text-align:center"><div style="font-size:28px">💳</div><h3 style="font-size:14px;margin:10px 0 6px">Local Payments</h3><p style="font-size:12.5px;color:var(--text-500)">COD, Bank Transfer, EasyPaisa & JazzCash supported.</p></div>
  </div>
</main>
<%- include('partials/footer') %>
</body>
</html>
