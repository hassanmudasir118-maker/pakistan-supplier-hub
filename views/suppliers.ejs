<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<main class="container">
  <div class="breadcrumbs"><a href="/">Home</a> / Suppliers</div>
  <div class="section-head">
    <div><h2>Supplier Directory</h2><p>Verified suppliers, wholesalers, manufacturers &amp; importers</p></div>
  </div>

  <div style="display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap">
    <input type="text" id="s-search" placeholder="Search suppliers..." style="max-width:280px">
    <select id="s-type" style="max-width:220px">
      <option value="">All Business Types</option>
      <option value="supplier">Supplier</option>
      <option value="wholesaler">Wholesaler</option>
      <option value="manufacturer">Manufacturer</option>
      <option value="importer">Importer</option>
      <option value="dropshipping_vendor">Dropshipping Vendor</option>
    </select>
    <label class="checkbox-row"><input type="checkbox" id="s-verified"> Verified only</label>
    <button class="btn btn-primary btn-sm" id="s-apply">Search</button>
  </div>

  <div class="grid-products" id="supplier-list" style="margin-bottom:60px"><div class="spinner"></div></div>
</main>
<%- include('partials/footer') %>
<script>
async function loadSuppliers(){
  const list = document.getElementById('supplier-list');
  list.innerHTML = '<div class="spinner"></div>';
  const q = new URLSearchParams();
  if (document.getElementById('s-search').value) q.set('q', document.getElementById('s-search').value);
  if (document.getElementById('s-type').value) q.set('businessType', document.getElementById('s-type').value);
  if (document.getElementById('s-verified').checked) q.set('verifiedOnly', '1');
  const { suppliers } = await PSH.api('/suppliers?' + q.toString());
  list.innerHTML = suppliers.length ? suppliers.map(s => `
    <a class="product-card" href="/supplier/${s.slug}">
      <div class="thumb"><img src="${s.banner_url || 'https://images.unsplash.com/photo-1556740758-90de374c12ad?w=400'}" alt="${PSH.escapeHtml(s.store_name)}" onerror="this.src='https://images.unsplash.com/photo-1556740758-90de374c12ad?w=400'"></div>
      <div class="body">
        <div class="store">${s.is_verified ? '<span class="badge badge-verified">✓ Verified</span>' : ''} ${s.is_featured ? '<span class="badge badge-featured">Featured</span>' : ''}</div>
        <div class="title">${PSH.escapeHtml(s.store_name)}</div>
        <div style="font-size:12px;color:var(--text-500);margin-bottom:6px;text-transform:capitalize">${s.business_type.replace('_',' ')} · ${PSH.escapeHtml(s.warehouse_city||'Pakistan')}</div>
        <div class="rating"><span class="stars">★</span> ${(s.rating_avg||0).toFixed(1)} (${s.rating_count}) · ${s.product_count} products</div>
      </div>
    </a>`).join('') : `<div class="empty-state" style="grid-column:1/-1"><div class="icon">🏬</div><p>No suppliers found.</p></div>`;
}
document.getElementById('s-apply').addEventListener('click', loadSuppliers);
loadSuppliers();
</script>
</body>
</html>
