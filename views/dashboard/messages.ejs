<%- include('../partials/head') %>
<body>
<%- include('../partials/header') %>
<div class="dash-shell" id="shell"><div class="spinner" style="margin:60px auto"></div></div>
<%- include('../partials/footer') %>
<script>
let ROLE = null;
const activeConvoId = new URLSearchParams(window.location.search).get('c');

async function init(){
  const user = await PSH.loadUser();
  if (!user) { window.location.href = '/login'; return; }
  ROLE = user.role;
  const sidebarPartial = ROLE === 'vendor' ? 'vendor' : ROLE === 'super_admin' ? 'admin' : 'customer';
  document.getElementById('shell').innerHTML = `
    <aside class="dash-sidebar" id="sidebar-slot"></aside>
    <main class="dash-main">
      <div class="dash-header"><h1>Messages</h1></div>
      <div style="display:grid;grid-template-columns:300px 1fr;gap:0;border:1px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;min-height:520px">
        <div style="border-right:1px solid var(--border);overflow-y:auto;max-height:600px" id="convo-list"><div class="spinner"></div></div>
        <div style="display:flex;flex-direction:column" id="thread-panel"><div class="empty-state" style="margin:auto"><div class="icon">💬</div><p>Select a conversation</p></div></div>
      </div>
    </main>`;
  loadSidebar(sidebarPartial);
  loadConversations();
}

async function loadSidebar(type){
  // simple inline nav matching the partials, since we can't include EJS partials from JS
  const navs = {
    vendor: [['/dashboard/vendor','Overview'],['/dashboard/vendor/products','Products'],['/dashboard/vendor/orders','Orders'],['/dashboard/vendor/earnings','Earnings'],['/dashboard/vendor/store','Store'],['/dashboard/messages','Messages']],
    admin: [['/dashboard/admin','Overview'],['/dashboard/admin/vendors','Vendors'],['/dashboard/admin/orders','Orders'],['/dashboard/messages','Messages']],
    customer: [['/dashboard','Overview'],['/dashboard/orders','My Orders'],['/wishlist','Wishlist'],['/dashboard/addresses','Addresses'],['/dashboard/reseller','Reseller Hub'],['/dashboard/messages','Messages']],
  };
  document.getElementById('sidebar-slot').innerHTML = `<div class="brand">My Account</div>` + navs[type].map(([href,label]) => `<a href="${href}" class="${href==='/dashboard/messages'?'active':''}">${label}</a>`).join('') + `<a href="/">&larr; Back to site</a>`;
}

async function loadConversations(){
  const { conversations } = await PSH.api('/conversations');
  const list = document.getElementById('convo-list');
  list.innerHTML = conversations.length ? conversations.map(c => `
    <div class="convo-item" data-id="${c.id}" style="padding:14px;border-bottom:1px solid var(--border);cursor:pointer;${c.id===activeConvoId?'background:#F4F7FC':''}">
      <div style="display:flex;justify-content:space-between"><strong style="font-size:13.5px">${PSH.escapeHtml(c.store_name || c.customer_name)}</strong>${c.unread_count>0?`<span class="badge-dot" style="position:static;display:flex">${c.unread_count}</span>`:''}</div>
      ${c.product_title ? `<div style="font-size:11.5px;color:var(--text-500)">Re: ${PSH.escapeHtml(c.product_title)}</div>` : ''}
      <div style="font-size:12px;color:var(--text-500);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${PSH.escapeHtml(c.last_message||'No messages yet')}</div>
    </div>`).join('') : '<div class="empty-state"><div class="icon">💬</div><p>No conversations yet.</p></div>';

  list.querySelectorAll('.convo-item').forEach(el => el.addEventListener('click', () => openThread(el.dataset.id)));
  if (activeConvoId) openThread(activeConvoId);
}

async function openThread(convoId){
  history.replaceState(null, '', '/dashboard/messages?c='+convoId);
  const panel = document.getElementById('thread-panel');
  panel.innerHTML = '<div class="spinner" style="margin:auto"></div>';
  const { messages } = await PSH.api('/conversations/'+convoId+'/messages');
  const user = PSH.getUser();
  panel.innerHTML = `
    <div style="flex:1;overflow-y:auto;padding:16px;max-height:480px" id="msg-list">
      ${messages.map(m => `<div style="display:flex;justify-content:${m.sender_id===user.id?'flex-end':'flex-start'};margin-bottom:10px">
        <div style="max-width:70%;padding:10px 14px;border-radius:14px;background:${m.sender_id===user.id?'var(--navy-700)':'#F0F3F8'};color:${m.sender_id===user.id?'#fff':'#101826'};font-size:13.5px">${PSH.escapeHtml(m.body)}</div>
      </div>`).join('') || '<div class="empty-state"><div class="icon">💬</div><p>Say hello!</p></div>'}
    </div>
    <div style="display:flex;gap:8px;padding:14px;border-top:1px solid var(--border)">
      <input type="text" id="msg-input" placeholder="Type a message..." style="flex:1">
      <button class="btn btn-primary btn-sm" id="send-btn">Send</button>
    </div>`;
  document.getElementById('msg-list').scrollTop = document.getElementById('msg-list').scrollHeight;
  document.getElementById('send-btn').addEventListener('click', () => sendMsg(convoId));
  document.getElementById('msg-input').addEventListener('keydown', (e) => { if (e.key === 'Enter') sendMsg(convoId); });
}

async function sendMsg(convoId){
  const input = document.getElementById('msg-input');
  if (!input.value.trim()) return;
  await PSH.api('/conversations/'+convoId+'/messages', { method:'POST', body:{body: input.value} });
  input.value = '';
  openThread(convoId);
}

init();
</script>
</body>
</html>
