<%- include('../../partials/head') %>
<body>
<%- include('../../partials/header') %>
<div class="dash-shell">
  <%- include('../../partials/vendor-sidebar') %>
  <main class="dash-main">
    <div class="dash-header">
      <h1>My Products</h1>
      <div style="display:flex;gap:8px">
        <a href="/dashboard/vendor/products/bulk-import" class="btn btn-secondary btn-sm">📥 Bulk Import</a>
        <a href="/dashboard/vendor/products/new" class="btn btn-primary btn-sm">+ Add Product</a>
      </div>
    </div>

    <div style="display:flex;gap:10px;margin-bottom:16px;flex-wrap:wrap;align-items:center">
      <input type="text" id="search-box" placeholder="Search your products..." style="flex:1;min-width:200px;padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13.5px">
      <select id="status-filter" style="padding:9px 12px;border:1px solid var(--border);border-radius:8px;font-size:13.5px">
        <option value="">All Status</option>
        <option value="active">Active</option>
        <option value="out_of_stock">Out of Stock</option>
        <option value="draft">Draft</option>
        <option value="suspended">Suspended</option>
      </select>
      <span id="product-count" style="font-size:13px;color:var(--text-500);white-space:nowrap">— products</span>
    </div>

    <div id="products-grid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px">
      <div class="spinner"></div>
    </div>
  </main>
</div>
<%- include('../../partials/footer') %>
<script>
let ALL_PRODUCTS = [];
const PLACEHOLDER_IMG = 'data:image/svg+xml;utf8,' + encodeURIComponent(`
  <svg xmlns="http://www.w3.org/2000/svg" width="240" height="160" viewBox="0 0 240 160">
    <rect width="240" height="160" fill="#F1F4F9"/>
    <path d="M90 95 L110 70 L130 90 L150 65 L165 95" stroke="#C3CCDB" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <circle cx="95" cy="70" r="8" fill="#C3CCDB"/>
    <text x="120" y="130" font-family="sans-serif" font-size="11" fill="#9AA5B8" text-anchor="middle">No image</text>
  </svg>`);

async function load(){
  const { products } = await PSH.api('/vendor/products');
  ALL_PRODUCTS = products;
  render();
}

function render(){
  const q = document.getElementById('search-box').value.trim().toLowerCase();
  const statusFilter = document.getElementById('status-filter').value;
  const filtered = ALL_PRODUCTS.filter(p => {
    if (statusFilter && p.status !== statusFilter) return false;
    if (q && !p.title.toLowerCase().includes(q)) return false;
    return true;
  });

  document.getElementById('product-count').textContent = `${filtered.length} of ${ALL_PRODUCTS.length} products`;

  const grid = document.getElementById('products-grid');
  if (!filtered.length) {
    grid.style.display = 'block';
    grid.innerHTML = ALL_PRODUCTS.length
      ? '<div class="empty-state"><div class="icon">🔍</div><p>No products match your search.</p></div>'
      : '<div class="empty-state"><div class="icon">📦</div><p>No products yet.</p><a href="/dashboard/vendor/products/new" class="btn btn-primary btn-sm" style="margin-top:10px">+ Add your first product</a></div>';
    return;
  }
  grid.style.display = 'grid';
  grid.innerHTML = filtered.map(p => `
    <div class="card" style="padding:0;overflow:hidden;display:flex;flex-direction:column">
      <div style="position:relative;aspect-ratio:3/2;background:#F1F4F9">
        <img src="${p.image_url || PLACEHOLDER_IMG}" onerror="this.onerror=null;this.src='${PLACEHOLDER_IMG}'"
             style="width:100%;height:100%;object-fit:cover;display:block">
        <span class="status-pill status-${p.status}" style="position:absolute;top:8px;left:8px;font-size:10.5px">${p.status.replace('_',' ')}</span>
      </div>
      <div style="padding:12px 14px;flex:1;display:flex;flex-direction:column">
        <div style="font-size:13.5px;font-weight:600;line-height:1.35;margin-bottom:6px;min-height:36px;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical">${PSH.escapeHtml(p.title)}</div>
        <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:4px">
          <strong style="font-size:15px;color:var(--navy-700)">${PSH.money(p.retail_price)}</strong>
          <span style="font-size:11.5px;color:${p.stock_quantity > 0 ? 'var(--text-500)' : 'var(--danger)'}">${p.stock_quantity > 0 ? p.stock_quantity + ' in stock' : 'Out of stock'}</span>
        </div>
        <div style="font-size:11px;color:var(--text-400);margin-bottom:10px">🛒 ${p.sold_count} sold</div>
        <div style="display:flex;gap:6px;margin-top:auto">
          <a href="/dashboard/vendor/products/${p.id}/edit" class="btn btn-secondary btn-sm" style="flex:1;text-align:center">✏️ Edit</a>
          <button class="btn btn-danger btn-sm" data-delete="${p.id}" style="flex:1">🗑️ Delete</button>
        </div>
      </div>
    </div>`).join('');

  document.querySelectorAll('[data-delete]').forEach(b => b.addEventListener('click', async () => {
    if (!confirm('Delete this product? This cannot be undone.')) return;
    try {
      await PSH.api('/vendor/products/'+b.dataset.delete, {method:'DELETE'});
      PSH.toast('Product deleted.', 'success');
      load();
    } catch(e) { PSH.toast(e.message, 'error'); }
  }));
}

document.getElementById('search-box').addEventListener('input', render);
document.getElementById('status-filter').addEventListener('change', render);

(async function(){
  const user = await PSH.loadUser();
  if (!user || user.role !== 'vendor') { window.location.href = '/login'; return; }
  load();
})();
</script>
</body>
</html>
