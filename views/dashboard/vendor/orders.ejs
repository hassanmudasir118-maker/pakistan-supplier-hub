<%- include('../../partials/head') %>
<body>
<%- include('../../partials/header') %>
<div class="dash-shell">
  <%- include('../../partials/vendor-sidebar') %>
  <main class="dash-main">
    <div class="dash-header"><h1>Orders</h1></div>
    <div class="tabs">
      <div class="tab active" data-s="">All</div>
      <div class="tab" data-s="pending">Pending</div>
      <div class="tab" data-s="confirmed">Confirmed</div>
      <div class="tab" data-s="processing">Processing</div>
      <div class="tab" data-s="shipped">Shipped</div>
      <div class="tab" data-s="delivered">Delivered</div>
      <div class="tab" data-s="cancelled">Cancelled</div>
    </div>
    <div id="orders-list"><div class="spinner"></div></div>

    <!-- Tracking Modal -->
    <div id="tracking-modal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:1000;align-items:center;justify-content:center">
      <div class="card" style="padding:24px;max-width:440px;width:90%;margin:0 auto">
        <h3 style="margin:0 0 16px">Add Tracking Info</h3>
        <div id="tracking-alert"></div>
        <div class="form-group">
          <label>Courier Name</label>
          <select id="t-courier" style="width:100%">
            <option value="">Select courier...</option>
            <option value="Leopards">Leopards Courier</option>
            <option value="TCS">TCS</option>
            <option value="Swyft">Swyft Logistics</option>
            <option value="Trax">Trax Logistics</option>
            <option value="PostEx">PostEx</option>
            <option value="M&P">M&P Express</option>
            <option value="Pakistan Post">Pakistan Post</option>
            <option value="Other">Other</option>
          </select>
        </div>
        <div class="form-group">
          <label>Tracking Number / AWB</label>
          <input type="text" id="t-number" placeholder="e.g. LP123456789PK">
        </div>
        <div class="form-group">
          <label>Tracking URL (optional — auto-generated for known couriers)</label>
          <input type="text" id="t-url" placeholder="https://...">
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px">
          <button class="btn btn-secondary" onclick="closeTracking()">Cancel</button>
          <button class="btn btn-primary" id="t-submit-btn" onclick="submitTracking()">Save & Mark Shipped</button>
        </div>
      </div>
    </div>
  </main>
</div>
<%- include('../../partials/footer') %>
<script>
const NEXT_STATUS = { pending:'confirmed', confirmed:'processing' };
const NEXT_LABEL  = { pending:'Confirm Order', confirmed:'Start Processing' };
let currentTrackingGroupId = null;

function openTracking(groupId) {
  currentTrackingGroupId = groupId;
  document.getElementById('t-courier').value = '';
  document.getElementById('t-number').value = '';
  document.getElementById('t-url').value = '';
  document.getElementById('tracking-alert').innerHTML = '';
  const modal = document.getElementById('tracking-modal');
  modal.style.display = 'flex';
}
function closeTracking() {
  document.getElementById('tracking-modal').style.display = 'none';
  currentTrackingGroupId = null;
}

async function submitTracking() {
  const courier = document.getElementById('t-courier').value;
  const number  = document.getElementById('t-number').value.trim();
  if (!courier || !number) {
    document.getElementById('tracking-alert').innerHTML = '<div class="alert alert-error">Courier and tracking number required.</div>';
    return;
  }
  const btn = document.getElementById('t-submit-btn');
  btn.disabled = true; btn.textContent = 'Saving…';
  try {
    await PSH.api('/vendor/orders/'+currentTrackingGroupId+'/tracking', {
      method:'PATCH',
      body: { courierName: courier, trackingNumber: number, trackingUrl: document.getElementById('t-url').value.trim() || undefined }
    });
    PSH.toast('Tracking added! Order marked as shipped.', 'success');
    closeTracking(); load(currentTab());
  } catch(err) {
    document.getElementById('tracking-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(err.message)}</div>`;
  } finally { btn.disabled = false; btn.textContent = 'Save & Mark Shipped'; }
}

async function load(status) {
  const wrap = document.getElementById('orders-list');
  wrap.innerHTML = '<div class="spinner"></div>';
  const { orders } = await PSH.api('/vendor/orders' + (status ? '?status='+status : ''));
  wrap.innerHTML = orders.length ? orders.map(o => `
    <div class="card" style="padding:18px;margin-bottom:14px">
      <div style="display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;margin-bottom:10px">
        <div>
          <strong>${o.order_number}</strong>
          <span class="status-pill status-${o.status}">${o.status.replace(/_/g,' ')}</span><br>
          <span style="font-size:12.5px;color:var(--text-500)">${PSH.escapeHtml(o.shipping_name)} · ${PSH.escapeHtml(o.shipping_phone)} · ${PSH.escapeHtml(o.shipping_city)}, ${PSH.escapeHtml(o.shipping_province)}</span><br>
          <span style="font-size:12.5px;color:var(--text-500)">${PSH.escapeHtml(o.shipping_address)}</span>
        </div>
        <div style="text-align:right">
          <div style="font-weight:800">${PSH.money(o.subtotal)}</div>
          <div style="font-size:11.5px;color:var(--text-500)">Your earning: <strong style="color:var(--teal-600)">${PSH.money(o.vendor_earning)}</strong></div>
          <div style="font-size:11px;color:var(--text-400)">Commission: ${PSH.money(o.commission_amount)} (${o.commission_percent}%)</div>
        </div>
      </div>
      <table class="data-table" style="margin-bottom:10px"><tbody>
        ${o.items.map(it => `<tr><td>${PSH.escapeHtml(it.product_title)}${it.variant_title?` <em>(${PSH.escapeHtml(it.variant_title)})</em>`:''}</td><td>×${it.quantity}</td><td style="text-align:right">${PSH.money(it.line_total)}</td></tr>`).join('')}
      </tbody></table>
      ${o.tracking_number ? `
        <div style="background:var(--teal-50,#f0fdf9);border:1px solid var(--teal-200,#99e6d3);border-radius:8px;padding:10px 14px;margin-bottom:10px;font-size:13px">
          🚚 <strong>${PSH.escapeHtml(o.courier_name)}</strong> — ${PSH.escapeHtml(o.tracking_number)}
          ${o.tracking_url ? `<a href="${PSH.escapeHtml(o.tracking_url)}" target="_blank" style="margin-left:8px;color:var(--teal-600)">Track →</a>` : ''}
        </div>` : ''}
      <div style="display:flex;gap:8px;justify-content:flex-end;flex-wrap:wrap">
        ${NEXT_STATUS[o.status] ? `<button class="btn btn-secondary btn-sm" data-next="${o.id}" data-status="${NEXT_STATUS[o.status]}">${NEXT_LABEL[o.status]}</button>` : ''}
        ${o.status === 'processing' ? `<button class="btn btn-primary btn-sm" onclick="openTracking('${o.id}')">📦 Add Tracking / Mark Shipped</button>` : ''}
        ${o.status === 'shipped' && !o.tracking_number ? `<button class="btn btn-secondary btn-sm" onclick="openTracking('${o.id}')">Add Tracking</button>` : ''}
        ${o.status === 'shipped' ? `<button class="btn btn-primary btn-sm" data-next="${o.id}" data-status="delivered">✅ Mark Delivered</button>` : ''}
        ${['pending','confirmed','processing'].includes(o.status) ? `<button class="btn btn-danger btn-sm" data-cancel="${o.id}">Cancel</button>` : ''}
      </div>
    </div>`).join('') : '<div class="empty-state"><div class="icon">📦</div><p>No orders found.</p></div>';

  wrap.querySelectorAll('[data-next]').forEach(b => b.addEventListener('click', async () => {
    await PSH.api('/vendor/orders/'+b.dataset.next+'/status', {method:'PATCH', body:{status:b.dataset.status}});
    PSH.toast('Order updated.', 'success'); load(currentTab());
  }));
  wrap.querySelectorAll('[data-cancel]').forEach(b => b.addEventListener('click', async () => {
    if (!confirm('Cancel this order?')) return;
    await PSH.api('/vendor/orders/'+b.dataset.cancel+'/status', {method:'PATCH', body:{status:'cancelled'}});
    PSH.toast('Order cancelled.', 'success'); load(currentTab());
  }));
}

function currentTab() { return document.querySelector('.tab.active').dataset.s; }
document.querySelectorAll('.tab').forEach(tab => tab.addEventListener('click', () => {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  tab.classList.add('active'); load(tab.dataset.s);
}));
document.getElementById('tracking-modal').addEventListener('click', function(e) {
  if (e.target === this) closeTracking();
});
(async function() {
  const user = await PSH.loadUser();
  if (!user || user.role !== 'vendor') { window.location.href = '/login'; return; }
  load('');
})();
</script>
</body>
</html>
