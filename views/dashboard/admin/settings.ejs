<%- include('../../partials/head') %>
<body>
<%- include('../../partials/header') %>
<div class="dash-shell">
  <%- include('../../partials/admin-sidebar') %>
  <main class="dash-main">
    <div class="dash-header"><h1>Platform Settings</h1></div>
    <div class="card" style="padding:26px;max-width:640px">
      <div id="form-alert"></div>
      <div class="form-group"><label>Platform Name</label><input type="text" id="s-name"></div>
      <div class="form-row">
        <div class="form-group">
          <label>Commission Type</label>
          <select id="s-commission-type" style="width:100%">
            <option value="percent">Percentage (%) — e.g. 10% of order value</option>
            <option value="flat">Flat Amount (Rs.) — e.g. Rs. 10, 12, 15 per order</option>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group" id="percent-field"><label>Commission Percentage (%)</label><input type="number" id="s-commission" step="0.1" min="0" max="100" placeholder="e.g. 10"></div>
          <div class="form-group" id="flat-field"><label>Flat Commission Amount (Rs.)</label><input type="number" id="s-commission-flat" step="1" min="0" placeholder="e.g. 10, 12, 15"></div>
        </div>
        <div class="form-group"><label>Flat Shipping Fee (Rs.)</label><input type="number" id="s-shipping"></div>
      </div>
      <div class="form-group"><label>Free Shipping Threshold (Rs., optional)</label><input type="number" id="s-free-shipping"></div>
      <div class="form-row">
        <div class="form-group"><label>Support Email</label><input type="email" id="s-support-email"></div>
        <div class="form-group"><label>Support Phone</label><input type="tel" id="s-support-phone"></div>
      </div>
      <div class="form-group"><label>Bank Transfer Details (shown at checkout)</label><textarea id="s-bank"></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>EasyPaisa Account</label><input type="text" id="s-easypaisa"></div>
        <div class="form-group"><label>JazzCash Account</label><input type="text" id="s-jazzcash"></div>
      </div>
      <button class="btn btn-primary" id="save-btn">Save Settings</button>
    </div>
  </main>
</div>
<%- include('../../partials/footer') %>
<script>
(async function(){
  const user = await PSH.loadUser();
  if (!user || user.role !== 'super_admin') { window.location.href = '/login'; return; }
  const { settings: s } = await PSH.api('/settings');
  document.getElementById('s-name').value = s.platform_name || '';
  document.getElementById('s-commission').value = s.global_commission_percent || 10;
  document.getElementById('s-commission-type').value = s.global_commission_type || 'percent';
  document.getElementById('s-commission-flat').value = s.global_commission_flat || 10;
  toggleCommissionFields();
  document.getElementById('s-commission-type').addEventListener('change', toggleCommissionFields);
  document.getElementById('s-shipping').value = s.flat_shipping_fee;
  document.getElementById('s-free-shipping').value = s.free_shipping_threshold || '';
  document.getElementById('s-support-email').value = s.support_email || '';
  document.getElementById('s-support-phone').value = s.support_phone || '';
  document.getElementById('s-bank').value = s.bank_transfer_details || '';
  document.getElementById('s-easypaisa').value = s.easypaisa_account || '';
  document.getElementById('s-jazzcash').value = s.jazzcash_account || '';
})();

document.getElementById('save-btn').addEventListener('click', async () => {
  try {
    await PSH.api('/admin/settings', { method: 'PUT', body: {
      platformName: document.getElementById('s-name').value,
      globalCommissionPercent: Number(document.getElementById('s-commission').value),
      globalCommissionType: document.getElementById('s-commission-type').value,
      globalCommissionFlat: Number(document.getElementById('s-commission-flat').value),
      flatShippingFee: Number(document.getElementById('s-shipping').value),
      freeShippingThreshold: document.getElementById('s-free-shipping').value ? Number(document.getElementById('s-free-shipping').value) : null,
      supportEmail: document.getElementById('s-support-email').value,
      supportPhone: document.getElementById('s-support-phone').value,
      bankTransferDetails: document.getElementById('s-bank').value,
      easypaisaAccount: document.getElementById('s-easypaisa').value,
      jazzcashAccount: document.getElementById('s-jazzcash').value,
    }});
    document.getElementById('form-alert').innerHTML = '<div class="alert alert-success">Settings saved.</div>';
  } catch(e) { document.getElementById('form-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(e.message)}</div>`; }
});

function toggleCommissionFields() {
  const type = document.getElementById('s-commission-type').value;
  document.getElementById('percent-field').style.display = type === 'percent' ? '' : 'none';
  document.getElementById('flat-field').style.display   = type === 'flat'    ? '' : 'none';
}
</script>
</body>
</html>
