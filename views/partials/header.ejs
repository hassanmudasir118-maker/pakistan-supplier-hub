<div class="topbar">
  <div class="container">
    <span><%= isShopDomain ? 'Wholesale prices, delivered nationwide — Cash on Delivery available' : "Pakistan's trusted wholesale & dropshipping marketplace" %></span>
    <span>
      <% if (!isShopDomain) { %><a href="/vendor/register">Sell on PSH</a> &nbsp;|&nbsp;<% } %>
      <a href="/contact">Help Center</a>
    </span>
  </div>
</div>

<header class="site-header">
  <div class="container header-row">
    <% if (isShopDomain) { %>
    <a href="/" class="logo pakbazaar-logo">
      <span class="pb-seal">PB</span>
      <span class="pb-word">Pak<span class="pb-word-accent">Bazaar</span></span>
    </a>
    <% } else { %>
    <a href="/" class="logo">
      <span class="mark">PS</span>
      <span>Supplier<span style="color:var(--teal-500)">Hub</span></span>
    </a>
    <% } %>

    <form class="search-bar" id="site-search-form">
      <input type="text" name="q" placeholder="Search products, brands, suppliers..." aria-label="Search">
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </button>
    </form>

    <div class="nav-actions">
      <a href="/wishlist" class="icon-btn" data-user-only style="display:none" aria-label="Wishlist">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
      </a>
      <a href="/cart" class="icon-btn" aria-label="Cart">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
        <span id="cart-count" class="badge-dot" style="display:none">0</span>
      </a>
      <a href="/dashboard/notifications" class="icon-btn" data-user-only style="display:none" aria-label="Notifications">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
        <span id="notif-count" class="badge-dot" style="display:none">0</span>
      </a>

      <div data-guest-only style="display:flex;gap:8px">
        <a href="/login" class="btn btn-outline btn-sm">Log in</a>
        <a href="/register" class="btn btn-primary btn-sm">Sign up</a>
      </div>

      <div class="user-menu" data-user-only style="display:none">
        <button id="user-menu-btn" class="icon-btn" style="width:auto;padding:0 10px;gap:6px;display:flex;align-items:center" aria-label="Account menu">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span data-user-name style="font-size:13px;font-weight:600"></span>
        </button>
        <div id="user-menu-dropdown" class="user-menu-dropdown">
          <a data-dash-link href="/dashboard">Dashboard</a>
          <a href="/dashboard/orders">My Orders</a>
          <a href="/dashboard/messages">Messages</a>
          <a href="/dashboard/addresses">Saved Addresses</a>
          <hr>
          <button id="logout-btn">Log out</button>
        </div>
      </div>
    </div>
  </div>

  <nav class="main-nav">
    <div class="container">
      <% if (!isShopDomain) { %><a href="/vendor/register" style="color:var(--teal-600,#0d9773);font-weight:700">🏪 Become a Vendor</a><% } %>
      <a href="/shop">Shop All</a>
      <a href="/categories">Categories</a>
      <a href="/suppliers">Suppliers</a>
      <a href="/shop?featured=1">Featured</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
  </nav>
</header>
