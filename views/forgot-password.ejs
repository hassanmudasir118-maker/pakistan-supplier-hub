<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<div class="auth-shell">
  <div class="auth-card">
    <h1>Reset your password</h1>
    <p class="sub">Enter your email and we'll send you a reset link.</p>
    <div id="form-alert"></div>
    <form id="forgot-form">
      <div class="form-group"><label>Email</label><input type="email" id="email" required></div>
      <button type="submit" class="btn btn-primary btn-block">Send Reset Link</button>
    </form>
    <p style="text-align:center;font-size:13.5px;margin-top:22px;color:var(--text-500)"><a href="/login" style="color:var(--navy-700);font-weight:600">← Back to login</a></p>
  </div>
</div>
<%- include('partials/footer') %>
<script>
document.getElementById('forgot-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  try {
    const res = await PSH.api('/auth/forgot-password', { method: 'POST', body: { email: document.getElementById('email').value } });
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-success">${PSH.escapeHtml(res.message)}</div>`;
  } catch(err) {
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(err.message)}</div>`;
  }
});
</script>
</body>
</html>
