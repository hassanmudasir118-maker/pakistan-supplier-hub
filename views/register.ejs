<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<div class="auth-shell">
  <div class="auth-card">
    <h1>Create your account</h1>
    <p class="sub">Shop, save favorites, and start reselling</p>
    <div id="form-alert"></div>
    <form id="register-form">
      <div class="form-group"><label>Full Name</label><input type="text" id="name" required></div>
      <div class="form-group"><label>Email</label><input type="email" id="email" required></div>
      <div class="form-group"><label>Phone</label><input type="tel" id="phone" placeholder="03XXXXXXXXX"></div>
      <div class="form-group"><label>Password</label><input type="password" id="password" required minlength="8"><div class="helper-text">At least 8 characters</div></div>
      <button type="submit" class="btn btn-primary btn-block">Create Account</button>
    </form>
    <div class="divider-or">OR</div>
    <a href="/api/auth/google" class="btn-google">
      <svg width="18" height="18" viewBox="0 0 18 18"><path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62z"/><path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.81.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.03-3.7H.96v2.33A9 9 0 0 0 9 18z"/><path fill="#FBBC05" d="M3.97 10.72A5.4 5.4 0 0 1 3.69 9c0-.6.1-1.18.28-1.72V4.95H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.05l3.01-2.33z"/><path fill="#EA4335" d="M9 3.58c1.32 0 2.51.45 3.44 1.35l2.59-2.59C13.46.89 11.43 0 9 0A9 9 0 0 0 .96 4.95l3.01 2.33C4.68 5.16 6.66 3.58 9 3.58z"/></svg>
      Continue with Google
    </a>
    <p style="text-align:center;font-size:13.5px;margin-top:22px;color:var(--text-500)">Already have an account? <a href="/login" style="color:var(--navy-700);font-weight:600">Log in</a></p>
    <p style="text-align:center;font-size:13.5px;color:var(--text-500)">Want to sell? <a href="/vendor/register" style="color:var(--navy-700);font-weight:600">Become a vendor</a></p>
  </div>
</div>
<%- include('partials/footer') %>
<script>
document.getElementById('register-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  try {
    await PSH.api('/auth/register', { method: 'POST', body: {
      name: document.getElementById('name').value,
      email: document.getElementById('email').value,
      phone: document.getElementById('phone').value,
      password: document.getElementById('password').value,
    }});
    window.location.href = '/';
  } catch(err) {
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(err.message)}</div>`;
  }
});
</script>
</body>
</html>
