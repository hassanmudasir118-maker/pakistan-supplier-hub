<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<div class="auth-shell">
  <div class="auth-card" id="intent-card">
    <h1>Welcome — what brings you here?</h1>
    <p class="sub">Pick one to get started</p>
    <div style="display:grid;gap:12px;margin-top:20px">
      <button type="button" id="intent-buy" class="intent-option">
        <span class="intent-icon">🛍️</span>
        <span class="intent-text">
          <strong>I want to buy products</strong>
          <span>Shop wholesale prices, track orders, save favorites</span>
        </span>
        <span class="intent-arrow">→</span>
      </button>
      <button type="button" id="intent-sell" class="intent-option">
        <span class="intent-icon">🏪</span>
        <span class="intent-text">
          <strong>I want to sell my products</strong>
          <span>List products, manage your store, track earnings</span>
        </span>
        <span class="intent-arrow">→</span>
      </button>
    </div>
    <p style="text-align:center;font-size:13.5px;margin-top:20px;color:var(--text-500)">Already have an account? <a href="/login" style="color:var(--navy-700);font-weight:600">Log in</a></p>
  </div>

  <div class="auth-card" id="buyer-card" style="display:none">
    <button type="button" id="back-to-intent" class="back-link">← Back</button>
    <h1>Create your account</h1>
    <p class="sub">Join Pakistan Supplier Hub as a buyer or reseller</p>
    <div id="form-alert"></div>
    <form id="register-form" novalidate>
      <div class="form-group">
        <label for="name">Full Name</label>
        <input type="text" id="name" name="name" autocomplete="name" required placeholder="Muhammad Ali">
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" autocomplete="email" required placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label for="phone">Phone (optional)</label>
        <input type="tel" id="phone" name="phone" autocomplete="tel" placeholder="03xx-xxxxxxx">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <div style="position:relative">
          <input type="password" id="password" name="password" autocomplete="new-password" required style="padding-right:42px" placeholder="At least 8 characters">
          <button type="button" id="pw-toggle" aria-label="Show password"
            style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-500);font-size:17px;line-height:1;padding:4px">👁</button>
        </div>
        <div class="helper-text">Must be at least 8 characters</div>
      </div>
      <button type="submit" id="reg-btn" class="btn btn-primary btn-block">Create Account</button>
    </form>
  </div>
</div>
<style>
.intent-option{
  display:flex;align-items:center;gap:14px;width:100%;text-align:left;
  padding:18px;border:1.5px solid var(--border);border-radius:12px;background:#fff;
  cursor:pointer;transition:.15s
}
.intent-option:hover{border-color:var(--navy-700);box-shadow:0 4px 16px rgba(31,58,95,.08);transform:translateY(-1px)}
.intent-icon{font-size:28px;flex-shrink:0}
.intent-text{flex:1;display:flex;flex-direction:column;gap:2px}
.intent-text strong{font-size:15px;color:var(--text-900)}
.intent-text span{font-size:12.5px;color:var(--text-500)}
.intent-arrow{font-size:18px;color:var(--text-400)}
.back-link{background:none;border:none;color:var(--text-500);font-size:13px;cursor:pointer;padding:0;margin-bottom:14px}
.back-link:hover{color:var(--navy-700)}
</style>
<%- include('partials/footer') %>
<script>
document.getElementById('intent-buy').addEventListener('click', () => {
  document.getElementById('intent-card').style.display = 'none';
  document.getElementById('buyer-card').style.display = 'block';
});
document.getElementById('intent-sell').addEventListener('click', () => {
  window.location.href = '/vendor/register';
});
document.getElementById('back-to-intent').addEventListener('click', () => {
  document.getElementById('buyer-card').style.display = 'none';
  document.getElementById('intent-card').style.display = 'block';
});

document.getElementById('pw-toggle').addEventListener('click', function() {
  const inp = document.getElementById('password');
  inp.type = inp.type === 'password' ? 'text' : 'password';
  this.textContent = inp.type === 'password' ? '👁' : '🙈';
});

document.getElementById('register-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const btn = document.getElementById('reg-btn');
  btn.disabled = true;
  btn.textContent = 'Creating account…';
  document.getElementById('form-alert').innerHTML = '';
  try {
    const { user } = await PSH.api('/auth/register', { method: 'POST', body: {
      name:     document.getElementById('name').value.trim(),
      email:    document.getElementById('email').value.trim(),
      phone:    document.getElementById('phone').value.trim(),
      password: document.getElementById('password').value,
    }});
    if (user && user.role === 'vendor') window.location.href = '/dashboard/vendor';
    else window.location.href = '/dashboard';
  } catch(err) {
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(err.message)}</div>`;
    btn.disabled = false;
    btn.textContent = 'Create Account';
  }
});
</script>
</body>
</html>
