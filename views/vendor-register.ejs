<%- include('partials/head') %>
<body>
<%- include('partials/header') %>
<main class="container" style="max-width:720px;padding:40px 20px">
  <div class="card" style="padding:36px">
    <h1 style="font-size:22px;margin:0 0 6px">Become a Vendor</h1>
    <p style="color:var(--text-500);font-size:13.5px;margin-bottom:26px">Register your business to start selling on Pakistan Supplier Hub. Your application will be reviewed by our team before you can list products.</p>
    <div id="form-alert"></div>
    <form id="vendor-form">
      <h3 style="font-size:14px;margin:0 0 14px">Account Details</h3>
      <div class="form-row">
        <div class="form-group"><label>Your Full Name</label><input type="text" id="name" required></div>
        <div class="form-group"><label>Email</label><input type="email" id="email" required></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Phone</label><input type="tel" id="phone" placeholder="03XXXXXXXXX"></div>
        <div class="form-group"><label>Password</label><input type="password" id="password" required minlength="8"></div>
      </div>

      <h3 style="font-size:14px;margin:22px 0 14px">Business Information</h3>
      <div class="form-row">
        <div class="form-group"><label>Business Name</label><input type="text" id="businessName" required></div>
        <div class="form-group">
          <label>Business Type</label>
          <select id="businessType" required>
            <option value="">Select type</option>
            <option value="supplier">Supplier</option>
            <option value="wholesaler">Wholesaler</option>
            <option value="manufacturer">Manufacturer</option>
            <option value="importer">Importer</option>
            <option value="dropshipping_vendor">Dropshipping Vendor</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label>Business Phone</label><input type="tel" id="businessPhone" required></div>
        <div class="form-group"><label>Business Email (optional)</label><input type="email" id="businessEmail"></div>
      </div>
      <div class="form-group"><label>CNIC / NTN (optional)</label><input type="text" id="cnicOrNtn"></div>

      <h3 style="font-size:14px;margin:22px 0 14px">Warehouse Information</h3>
      <div class="form-group"><label>Warehouse Address</label><textarea id="warehouseAddress"></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>City</label><input type="text" id="warehouseCity"></div>
        <div class="form-group">
          <label>Province</label>
          <select id="warehouseProvince">
            <option value="">Select Province</option>
            <option>Punjab</option><option>Sindh</option><option>Khyber Pakhtunkhwa</option>
            <option>Balochistan</option><option>Gilgit-Baltistan</option><option>Azad Kashmir</option><option>Islamabad Capital Territory</option>
          </select>
        </div>
      </div>

      <button type="submit" class="btn btn-primary btn-block" style="margin-top:10px">Submit Application</button>
    </form>
    <p style="text-align:center;font-size:13.5px;margin-top:18px;color:var(--text-500)">Already a vendor? <a href="/login" style="color:var(--navy-700);font-weight:600">Log in</a></p>
  </div>
</main>
<%- include('partials/footer') %>
<script>
document.getElementById('vendor-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  try {
    const res = await PSH.api('/auth/register-vendor', { method: 'POST', body: {
      name: document.getElementById('name').value,
      email: document.getElementById('email').value,
      phone: document.getElementById('phone').value,
      password: document.getElementById('password').value,
      businessName: document.getElementById('businessName').value,
      businessType: document.getElementById('businessType').value,
      businessPhone: document.getElementById('businessPhone').value,
      businessEmail: document.getElementById('businessEmail').value,
      cnicOrNtn: document.getElementById('cnicOrNtn').value,
      warehouseAddress: document.getElementById('warehouseAddress').value,
      warehouseCity: document.getElementById('warehouseCity').value,
      warehouseProvince: document.getElementById('warehouseProvince').value,
    }});
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-success">${PSH.escapeHtml(res.message)}</div>`;
    setTimeout(() => window.location.href = '/dashboard/vendor', 1500);
  } catch(err) {
    document.getElementById('form-alert').innerHTML = `<div class="alert alert-error">${PSH.escapeHtml(err.message)}</div>`;
  }
});
</script>
</body>
</html>
